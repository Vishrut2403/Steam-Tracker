{
  "name": "steam-tracker",
  "version": "1.0.0",
  "homepage": "https://github.com/Vishrut2403/Steam-Tracker",
  "description": "Steam game library tracker and analyzer",
  "main": "main.js",
  "author": {
    "name": "Vishrut Sachan",
    "email": "vishrutsachan2004@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:electron\"",
    "start:backend": "cd ../backend && npm run dev",
    "start:frontend": "cd ../frontend && npm run dev",
    "start:electron": "wait-on http://localhost:5173 && electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.steamtracker.app",
    "productName": "Steam Tracker",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!.env"
        ]
      },
      {
      "from": "../frontend/dist",
      "to": "frontend"
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Game",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}