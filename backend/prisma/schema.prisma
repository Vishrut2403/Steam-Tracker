generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  steamId       String         @unique
  steamUsername  String?
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  libraryGames    LibraryGame[]
  wishlistGames   SteamWishlist[]
  gameSessions    GameSession[]
  journalEntries  GameJournalEntry[]

  @@map("users")
}

model LibraryGame {
  id              String   @id @default(uuid())
  userId          String
  
  // Multi-platform support
  platform        String   @default("steam")
  platformGameId  String
  appId           String?  // Keep for backward compatibility
  
  name            String
  playtimeForever Int      @default(0)
  pricePaid       Float?
  pricePerHour    Float?
  genres          String[]
  userTags        String[]
  
  status          String?  @default("unplayed")
  rating          Int?
  tier            String?
  review          String?
  
  imgIconUrl      String?
  imgLogoUrl      String?
  headerImage     String?
  
  totalAchievements      Int?     @default(0)
  completedAchievements  Int?     @default(0)
  achievementPercentage  Float?   @default(0)
  
  platformData           Json?
  
  minecraftWorldName     String?
  minecraftWorldPath     String?
  minecraftInstanceName  String?
  minecraftUUID          String?
  minecraftStats         Json?
  
  emulatorType           String?
  emulatorGame           String?
  retroAchievementsId    String?
  retroAchievementsData  Json?
  
  completedAt    DateTime?
  lastPlayedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameSessions GameSession[]
  journalEntries GameJournalEntry[]

  @@unique([userId, platform, platformGameId])
  @@unique([userId, appId])
  @@index([userId])
  @@index([userId, platform])
  @@index([platform])
  @@index([status])
  @@index([tier])
  @@index([rating])
  @@map("library_games")
}

model GameSession {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  platform  String
  
  date      DateTime // Date of the session (normalized to start of day)
  minutes   Int      // Minutes played in this session
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game LibraryGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, date])
  @@index([userId])
  @@index([gameId])
  @@index([userId, date])
  @@index([platform])
  @@map("game_sessions")
}

// Game journal entries - personal notes for each game
model GameJournalEntry {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  
  heading   String   // Entry heading/title (e.g., "End of Act 1")
  content   String   @db.Text // Journal entry text (can be long)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game LibraryGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([userId])
  @@index([createdAt])
  @@map("game_journal_entries")
}

model SteamWishlist {
  id              String   @id @default(uuid())
  userId          String
  name            String
  tags            String[]
  listPrice       Float
  currentPrice    Float
  
  recommendationScore Float    @default(0)
  discountPercent     Float    @default(0)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name]) 
  @@index([userId])
  @@index([recommendationScore])
  @@map("steam_wishlist")
}
