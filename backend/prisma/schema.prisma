generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  username      String   @unique
  displayName   String?
  avatar        String?
  
  xp            Int      @default(0)
  level         Int      @default(1)
  
  steamId       String?  @unique
  steamUsername String?
  steamAvatar   String?
  steamLinkedAt DateTime?
  
  raUsername    String?
  raApiKey      String?
  raLinkedAt    DateTime?
  
  enablePCSX2   Boolean  @default(false)
  enableRPCS3   Boolean  @default(false)
  enablePPSSPP  Boolean  @default(false)
  
  autoSyncSteam     Boolean @default(false)
  autoSyncRA        Boolean @default(false)
  autoSyncEmulators Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?
  
  games          LibraryGame[]
  sessions       GameSession[]
  journalEntries GameJournalEntry[]
  wishlistGames  SteamWishlist[]
  
  @@map("users")
}

model LibraryGame {
  id                 String   @id @default(uuid())
  userId             String
  platform           String   // 'steam', 'retroachievements', 'pcsx2', 'rpcs3', 'ppsspp', 'apple_gc', 'minecraft'
  platformGameId     String
  name               String
  imageUrl           String?
  playtimeForever    Int?     // minutes
  lastPlayedAt       DateTime?
  
  // User data
  status             String?  // 'playing', 'completed', 'backlog'
  rating             Int?     // 1-5 stars
  review             String?  @db.Text
  userTags           String[] @default([])
  
  // Steam-specific
  pricePaid          Float?
  pricePerHour       Float?
  
  // Achievement data
  achievementsTotal  Int?
  achievementsEarned Int?
  
  // Platform-specific metadata
  platformData       Json?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions GameSession[]
  journalEntries GameJournalEntry[]
  
  @@unique([userId, platformGameId, platform])
  @@index([userId])
  @@index([platform])
  @@index([status])
  @@map("library_games")
}

model GameSession {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  platform  String
  date      DateTime // Start of day (UTC) for this session
  minutes   Int      // Total minutes played on this date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game LibraryGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@unique([userId, gameId, date])
  @@index([userId])
  @@index([gameId])
  @@index([date])
  @@map("game_sessions")
}

model GameJournalEntry {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  heading   String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game LibraryGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@index([gameId])
  @@index([userId])
  @@index([createdAt])
  @@map("game_journal_entries")
}

model SteamWishlist {
  id                  String   @id @default(uuid())
  userId              String
  appId               String
  name                String
  tags                String[]
  listPrice           Float
  currentPrice        Float
  discountPercent     Int
  recommendationScore Int?
  imageUrl            String?

  // HLTB data
  hltbMain            Float?   
  hltbExtra           Float?  
  hltbCompletionist   Float? 
  hltbName            String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, appId])
  @@index([userId])
  @@map("steam_wishlist")
}